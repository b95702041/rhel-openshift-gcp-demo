# Copy this file to terraform.tfvars and fill in your values
# cp terraform.tfvars.example terraform.tfvars

project_id = "your-gcp-project-id"
region     = "asia-east1"
zone       = "asia-east1-b"

# CRC VM uses n2-standard-8 by default (nested virtualization requires N1/N2/C2 series)
# Uncomment below to override:
# crc_machine_type = "n2-standard-8"

# Your public SSH key (optional, gcloud SSH works without this)
# ssh_public_key = "ssh-rsa AAAA..."
