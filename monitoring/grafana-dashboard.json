{
  "annotations": { "list": [] },
  "editable": true,
  "title": "Demo API Dashboard",
  "uid": "demo-api-dashboard",
  "version": 1,
  "panels": [
    {
      "title": "App Uptime (seconds)",
      "type": "stat",
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "app_uptime_seconds",
          "legendFormat": "{{ pod }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "steps": [
              { "color": "red", "value": 0 },
              { "color": "yellow", "value": 300 },
              { "color": "green", "value": 3600 }
            ]
          }
        }
      }
    },
    {
      "title": "HTTP Request Rate (5m avg)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 16, "x": 8, "y": 0 },
      "targets": [
        {
          "expr": "rate(flask_http_request_total[5m])",
          "legendFormat": "{{ method }} {{ status }} {{ path }}"
        }
      ]
    },
    {
      "title": "Pod Count",
      "type": "stat",
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 6 },
      "targets": [
        {
          "expr": "count(app_info)",
          "legendFormat": "Running Pods"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "red", "value": 0 },
              { "color": "green", "value": 2 }
            ]
          }
        }
      }
    },
    {
      "title": "Container CPU Usage",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "targets": [
        {
          "expr": "rate(container_cpu_usage_seconds_total{container=\"demo-api\"}[5m])",
          "legendFormat": "{{ pod }}"
        }
      ]
    },
    {
      "title": "Container Memory Usage",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "targets": [
        {
          "expr": "container_memory_working_set_bytes{container=\"demo-api\"}",
          "legendFormat": "{{ pod }}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "bytes" }
      }
    }
  ],
  "time": { "from": "now-1h", "to": "now" },
  "refresh": "10s"
}
